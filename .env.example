# ═══════════════════════════════════════════════════════════════════
# MICROHARD AGENCY — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git — it contains secrets.
# ═══════════════════════════════════════════════════════════════════

# ─── PLANE ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
PLANE_SECRET_KEY=your-plane-secret-key-here

# URL where Plane is accessible (keep as-is for local)
WEB_URL=http://localhost:3000

# Plane database credentials
PLANE_DB_USER=plane
PLANE_DB_PASSWORD=your-plane-db-password-here
PLANE_DB_NAME=plane

# MinIO credentials (Plane file storage)
# Generate user: openssl rand -hex 12
# Generate password: openssl rand -hex 24 (must be >= 8 chars)
MINIO_ROOT_USER=your-minio-user-here
MINIO_ROOT_PASSWORD=your-minio-password-here

# ─── INVOICE NINJA ──────────────────────────────────────────────────
# Generate: echo "base64:$(openssl rand -base64 32)"
IN_APP_KEY=base64:your-invoice-ninja-app-key-here

# Invoice Ninja database credentials
IN_DB_NAME=ninja
IN_DB_USER=ninja
IN_DB_PASSWORD=your-invoice-ninja-db-password-here
IN_DB_ROOT_PASSWORD=your-invoice-ninja-db-root-password-here
